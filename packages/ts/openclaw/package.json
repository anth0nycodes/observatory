{
  "name": "@contextcompany/openclaw",
  "version": "2.0.0",
  "description": "AI agent observability that finds patterns in production and helps teams improve their agents",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "src",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ],
    "install": {
      "clawhubSpec": "clawhub:@contextcompany/openclaw",
      "npmSpec": "@contextcompany/openclaw",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.7.1"
    },
    "compat": {
      "pluginApi": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build --watch"
  },
  "sideEffects": false,
  "keywords": [
    "openclaw",
    "observability",
    "tracing",
    "monitoring",
    "context-company",
    "ai-agents"
  ],
  "homepage": "https://docs.thecontextcompany.com/frameworks/openclaw",
  "bugs": {
    "url": "https://github.com/The-Context-Company/observatory/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Context-Company/observatory",
    "directory": "packages/ts/openclaw"
  },
  "author": "The Context Company",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.22.3 <23 || >=24.15.0 <25 || >=25.9.0"
  },
  "dependencies": {
    "@contextcompany/api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
