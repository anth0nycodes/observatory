{
  "name": "@contextcompany/langchain",
  "version": "1.2.5",
  "description": "The Context Company integration for LangChain.js and LangGraph",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build --watch"
  },
  "sideEffects": false,
  "keywords": [
    "langchain",
    "langgraph",
    "observability",
    "tracing",
    "monitoring",
    "context-company"
  ],
  "homepage": "https://docs.thecontextcompany.com/frameworks/langchain-langgraph",
  "bugs": {
    "url": "https://github.com/The-Context-Company/observatory/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Context-Company/observatory",
    "directory": "packages/ts/langchain"
  },
  "author": "The Context Company",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0"
  },
  "dependencies": {
    "@contextcompany/api": "workspace:*"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.80",
    "@types/node": "^20.19.37",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
