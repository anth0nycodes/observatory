{
  "name": "@contextcompany/pi",
  "version": "1.2.0",
  "description": "The Context Company instrumentation for Pi Agent SDK",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./extension": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js",
      "require": "./dist/extension.cjs"
    }
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build --watch"
  },
  "sideEffects": false,
  "keywords": [
    "pi",
    "pi-mono",
    "agent",
    "observability",
    "tracing",
    "monitoring",
    "context-company",
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Context-Company/observatory",
    "directory": "packages/ts/pi"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.50.0"
  },
  "dependencies": {
    "@contextcompany/api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
